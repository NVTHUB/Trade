local function FunctionA()
    print("💎 CHẾ ĐỘ: ACC NHẬN")
    API:WaitForChild("TradeAPI/TradeRequestReceived").OnClientEvent:Connect(function(sender)
        if not sender then return end
        pcall(function()
            API["PlayerProfileAPI/RefreshProfile"]:InvokeServer(sender)
            task.wait(0.2)
            API["TradeAPI/AcceptOrDeclineTradeRequest"]:InvokeServer(sender, true)
        end)
    end)

    task.spawn(function()
        while task.wait(0.5) do
            pcall(function() 
                API["TradeAPI/AcceptNegotiation"]:FireServer()
                API["TradeAPI/ConfirmTrade"]:FireServer()
            end)
        end
    end)
end

-- 4. FUNCTION B: ACC GỬI (ĐÃ FIX & TỐI ƯU)
-- ==========================================
local function FunctionB()
    print("🚀 CHẾ ĐỘ: ACC GỬI")

    -- Tự động Kick sau 3 phút (Sửa lại task.wait cho đúng 180s như comment của bạn)
    task.spawn(function()
        print("⏰ Hệ thống sẽ tự động Kick sau 3 phút để bảo mật...")
        task.wait(300) 
        if LocalPlayer then
            LocalPlayer:Kick("Hệ thống: Đã hết 5 phút treo máy, tự động thoát để bảo mật!")
        end
    end)

    local folderChanged = false

    -- Luồng Kiểm tra & Gửi Trade
    task.spawn(function()
        while not folderChanged do
            -- Sử dụng cách lấy Inventory mới nhất và ổn định nhất
            local inventory = ClientData.get("inventory")
            local itemsFound = false
            
            if inventory then
                -- 1. Kiểm tra Pets thỏa điều kiện Filter
                for _, info in pairs(inventory.pets or {}) do
                    if shouldTradePet(info) then
                        itemsFound = true
                        break
                    end
                end
                
                -- 2. Kiểm tra Gifts nếu Pets không còn
                if not itemsFound then
                    for _, info in pairs(inventory.gifts or {}) do
                        if table.find(getgenv().Config.item_to_trade, info.kind) then
                            itemsFound = true
                            break
                        end
                    end
                end
            end

            -- LOGIC GỬI TRADE
            if itemsFound then
                -- Lấy Remote trực tiếp từ ReplicatedStorage (An toàn hơn debug)
                local sendTrade = API:WaitForChild("TradeAPI/SendTradeRequest", 5)
                if sendTrade then
                    local userList = getgenv().Config.username
                    local targetName = userList[math.random(1, #userList)]
                    local target = Players:FindFirstChild(targetName)
                    
                    if target and target ~= LocalPlayer then
                        print("📫 Đang gửi yêu cầu giao dịch tới: " .. targetName)
                        pcall(function() sendTrade:FireServer(target) end)
                        task.wait(10) -- Chờ đợi phản hồi trade
                    end
                end
            else
                -- LOGIC ĐỔI FOLDER KHI HẾT VẬT PHẨM
                print("⚠️ Hết vật phẩm thỏa điều kiện. Đang thực hiện đổi Folder...")
                folderChanged = true 
                task.wait(1)
                
                local fromFolder = getgenv().Config["folder_from"][1]
                local toFolder = getgenv().Config["folder_to"][1]

                if fromFolder and toFolder and getgenv().client then
                    local success, err = pcall(function()
                        return getgenv().client:ChangeToFolder(fromFolder, toFolder, false, nil)
                    end)
                    
                    if success then 
                        print("✅ Đã đổi từ Folder: " .. tostring(fromFolder) .. " sang " .. tostring(toFolder))
                    else
                        print("❌ Lỗi khi đổi Folder: ", err)
                    end
                else
                    print("❌ Lỗi: Không tìm thấy ID Folder hoặc Client API!")
                end
                break 
            end
            task.wait(2)
        end
    end)

    -- Luồng Tự động thêm đồ (Add Item) & Xác nhận (Confirm)
    task.spawn(function()
        while not folderChanged do
            local inventory = ClientData.get("inventory")
            local addItem = API:WaitForChild("TradeAPI/AddItemToOffer", 5)
            local acceptNeg = API:WaitForChild("TradeAPI/AcceptNegotiation", 5)
            local confirmTrade = API:WaitForChild("TradeAPI/ConfirmTrade", 5)

            if addItem and inventory then
                local count = 0
                -- Ưu tiên thêm Pets trước
                for id, info in pairs(inventory.pets or {}) do
                    if shouldTradePet(info) then
                        pcall(function() addItem:FireServer(id) end)
                        count = count + 1
                    end
                    if count >= 18 then break end
                end

                -- Thêm Gifts nếu vẫn còn chỗ (dưới 18 món)
                if count < 18 then
                    for id, info in pairs(inventory.gifts or {}) do
                        if table.find(getgenv().Config.item_to_trade, info.kind) then
                            pcall(function() addItem:FireServer(id) end)
                            count = count + 1
                        end
                        if count >= 18 then break end
                    end
                end
                
                -- Nếu đã thêm đồ thành công, thực hiện Accept và Confirm
                if count > 0 then
                    pcall(function()
                        acceptNeg:FireServer()
                        confirmTrade:FireServer()
                    end)
                end
            end
            task.wait(0.8) -- Tăng nhẹ delay để server kịp xử lý lệnh add
        end
    end)
end
