local function waitUntil(fn, timeout)
    local t0 = os.clock()
    while true do
        local ok, done = pcall(fn)
        if ok and done then return true end
        if timeout and os.clock() - t0 >= timeout then return false end
        task.wait(0.25)
    end
end

local function normalizeList(raw)
    if type(raw) == "table" then return raw end
    if type(raw) == "string" then
        local list = {}
        for item in string.gmatch(raw, "[^,]+") do
            local cleaned = string.gsub(item, "^%s+", "")
            cleaned = string.gsub(cleaned, "%s+$", "")
            if cleaned ~= "" then table.insert(list, cleaned) end
        end
        return list
    end
    return {}
end

local function getItemCount(category, kind)
    local inventory = ClientData.get("inventory")
    if not inventory or not inventory[category] then return 0 end
    local count = 0
    for _, info in pairs(inventory[category]) do
        if info.kind == kind then count = count + 1 end
    end
    return count
end

local function getPetState(info)
    local props = (info and info.properties) or {}
    local isMega = props.mega_neon == true
    local isNeon = props.neon == true
    local age = tonumber(props.age or 1) or 1
    return isMega, isNeon, age
end

