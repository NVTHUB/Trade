local function runAutoBuy()
    local config = g.Config.AutoBuy
    if not config or not config.Enabled then return end

    local buyItems = normalizeList(config.SelectedItems)
    local buyAmounts = config.BuyAmounts or {}
    for i = 1, #buyItems do
        local split = string.split(buyItems[i], "|")
        local category = split[1]
        local itemName = split[2]
        local targetAmount = tonumber(buyAmounts[i]) or 0
        if category and itemName then
            while true do
                local before = getItemCount(category, itemName)
                if targetAmount > 0 and before >= targetAmount then
                    State.AutoBuy.Message = "Da du: " .. itemName
                    break
                end
                pcall(function()
                    API:WaitForChild("ShopAPI/BuyItem"):InvokeServer(category, itemName, { buy_count = 1 })
                end)
                task.wait(1.5)
                local after = getItemCount(category, itemName)
                if after <= before then
                    State.AutoBuy.Message = "Het tien"
                    break
                end
                State.AutoBuy.LastBought = itemName
                State.AutoBuy.Message = "Da mua: " .. itemName
                task.wait(0.5)
            end
        end
    end
end

local function runAutoOpen()
    local config = g.Config.AutoOpen
    if not config or not config.Enabled then return end

    local allowedMap = {}
    for _, item in ipairs(normalizeList(config.Items)) do allowedMap[item] = true end
    local inventory = ClientData.get("inventory")
    if not inventory or not inventory.gifts then return end

    local itemsToOpen = {}
    for id, info in pairs(inventory.gifts) do
        if allowedMap[info.kind] then
            table.insert(itemsToOpen, { id = id, kind = info.kind })
        end
    end
    if #itemsToOpen == 0 then
        State.AutoOpen.Current = "None"
        State.AutoOpen.Message = "Mo xong"
        return
    end

    for _, item in ipairs(itemsToOpen) do
        State.AutoOpen.Current = item.kind
        State.AutoOpen.Message = "Dang mo: " .. item.kind
        while equipLock do task.wait(0.5) end
        equipLock = true
        pcall(function()
            API:WaitForChild("ToolAPI/Equip"):InvokeServer(item.id, { use_sound_delay = true, equip_as_last = false })
            API:WaitForChild("ToolAPI/ServerUseTool"):FireServer(item.id, "START")
            task.wait(0.5)
            API:WaitForChild("LootBoxAPI/ExchangeItemForReward"):InvokeServer(item.kind, item.id)
            task.wait(0.2)
            API:WaitForChild("ToolAPI/Unequip"):InvokeServer(item.id)
        end)
        equipLock = false
        task.wait(1)
    end
    State.AutoOpen.Current = "None"
    State.AutoOpen.Message = "Mo xong"
end

local function runAutoNeonMega()
    local config = g.Config.AutoNeon
    if not config or not config.Enabled then return end
    local inventory = ClientData.get("inventory")
    if not inventory or not inventory.pets then return end

    local groups = {}
    for id, info in pairs(inventory.pets) do
        local isMega, isNeon, age = getPetState(info)
        if age == 6 and not isMega then
            if config.MakeNeon and not isNeon then
                local k = (info.kind or "unknown") .. "|normal"
                groups[k] = groups[k] or {}
                table.insert(groups[k], id)
            elseif config.MakeMega and isNeon then
                local k = (info.kind or "unknown") .. "|neon"
                groups[k] = groups[k] or {}
                table.insert(groups[k], id)
            end
        end
    end

    for groupKey, ids in pairs(groups) do
        local i = 1
        while i + 3 <= #ids do
            local mats = { ids[i], ids[i + 1], ids[i + 2], ids[i + 3] }
            local success = pcall(function()
                API:WaitForChild("PetAPI/DoNeonFusion"):InvokeServer(mats)
            end)
            if success then
                if string.find(groupKey, "|neon") then
                    State.AutoNeon.MegaCount = State.AutoNeon.MegaCount + 1
                else
                    State.AutoNeon.Count = State.AutoNeon.Count + 1
                end
                State.AutoNeon.Current = groupKey
            end
            i = i + 4
            task.wait(1.5)
        end
    end
end

local PET_XP_DATA = {
    common = 2500,
    uncommon = 3600,
    rare = 5400,
    ultra_rare = 10700,
    legendary = 18300
}
local POTION_XP_VALUE = 300

local function getPetRarity(info)
    return string.lower((info and info.rarity) or (info and info.pet_rarity) or "common")
end

local function runAutoPotion()
    local config = g.Config.AutoPotion
    if not config or not config.Enabled then return end
    local inv = ClientData.get("inventory")
    if not inv or not inv.pets then return end

    local pots = {}
    for id, info in pairs(inv.food or {}) do
        if info.kind == "pet_age_potion" then table.insert(pots, id) end
    end
    State.AutoPotion.Count = #pots
    if #pots == 0 then
        State.AutoPotion.Out = true
        State.AutoPotion.Message = "HET POTION"
        State.AutoPotion.Current = "None"
        return
    end
    State.AutoPotion.Out = false

    local selected = normalizeList(config.SelectedPets)
    local candidates = {}
    for id, info in pairs(inv.pets) do
        local props = info.properties or {}
        local age = tonumber(props.age or 1)
        if age < 6 and not props.mega_neon then
            local priority = 999
            for i, name in ipairs(selected) do
                if name == info.kind then
                    priority = i
                    break
                end
            end
            if priority ~= 999 or #selected == 0 then
                table.insert(candidates, { id = id, kind = info.kind, priority = priority, xp = props.xp or 0 })
            end
        end
    end
    if #candidates == 0 then
        State.AutoPotion.Current = "None"
        State.AutoPotion.Message = "Khong co pet can up"
        return
    end
    table.sort(candidates, function(a, b)
        if a.priority ~= b.priority then return a.priority < b.priority end
        return a.xp > b.xp
    end)
    local target = candidates[1]
    State.AutoPotion.Current = target.kind
    State.AutoPotion.Message = "Dang nang cap: " .. target.kind

    pcall(function()
        local targetInfo = inv.pets[target.id]
        local rarity = getPetRarity(targetInfo)
        local maxXP = PET_XP_DATA[rarity] or 2500
        local currentXP = (targetInfo and targetInfo.properties and targetInfo.properties.xp) or target.xp or 0
        local neededPotions = math.max(1, math.ceil((maxXP - currentXP) / POTION_XP_VALUE))
        local batchSize = math.min(#pots, neededPotions)

        local mainPotionId = pots[1]
        local additional = {}
        for i = 2, batchSize do
            table.insert(additional, pots[i])
        end

        API:WaitForChild("ToolAPI/Equip"):InvokeServer(target.id)
        task.wait(0.5)
        API:WaitForChild("ToolAPI/Equip"):InvokeServer(mainPotionId, { use_sound_delay = false, equip_as_last = false })
        task.wait(0.5)
        API:WaitForChild("PetObjectAPI/CreatePetObject"):InvokeServer("__Enum_PetObjectCreatorType_2", {
            additional_consume_uniques = additional,
            pet_unique = target.id,
            unique_id = mainPotionId
        })
        task.wait(0.5)
        local petObjects = workspace:FindFirstChild("PetObjects")
        local obj = petObjects and petObjects:FindFirstChild("AgePotion")
        if obj then
            API:WaitForChild("PetAPI/ConsumeFoodObject"):FireServer(obj, target.id)
        end
        State.AutoPotion.Message = "Da feed x" .. tostring(batchSize) .. ": " .. target.kind
        task.wait(1)
    end)
end

