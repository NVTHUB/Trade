local function ensureSection(name, defaults)
    if type(g.Config[name]) ~= "table" then
        g.Config[name] = {}
    end
    for k, v in pairs(defaults) do
        if g.Config[name][k] == nil then
            g.Config[name][k] = v
        end
    end
end

